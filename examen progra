planes = {
    'F001': ['Plan Básico', 'mensual', 1, False, False, 'libre'],
    'F002': ['Plan Full', 'mensual', 1, True, True, 'libre'],
    'F003': ['Plan Estudiante', 'trimestral', 3, False, True, 'tarde'],
    'F004': ['Plan Senior', 'trimestral', 3, True, False, 'mañana'],
    'F005': ['Plan Anual Pro', 'anual', 12, True, True, 'libre'],
    'F006': ['Plan Nocturno', 'mensual', 1, False, True, 'noche']
}


inscripciones = {
    'F001': [25000, 20],
    'F002': [35000, 25],
    'F003': [20000, 15],
    'F004': [22000, 12],
    'F005': [150000, 30],
    'F006': [18000, 10]
}

def buscar_codigo(codigo, diccionario):

    for clave in diccionario:
        if clave.upper() == codigo.upper():
            return True
    return False


def cupos_tipo(tipo, dicc_planes, dicc_inscripciones):
  
    total_cupos = 0
    for codigo, info_plan in dicc_planes.items():
        if info_plan[1].lower() == tipo.lower():
            if codigo in dicc_inscripciones:
                total_cupos += dicc_inscripciones[codigo][1]
                
    print(f"El total de cupos disponibles es: {total_cupos}")


def busqueda_precio(p_min, p_max, dicc_planes, dicc_inscripciones):
 
    resultados = []
    for codigo, info_ins in dicc_inscripciones.items():
        precio = info_ins[0]
        cupos = info_ins[1]
        
        if p_min <= precio <= p_max and cupos > 0:
            nombre_plan = dicc_planes[codigo][0] if codigo in dicc_planes else "Desconocido"
            resultados.append(f"{nombre_plan}--{codigo.upper()}")
            
    if resultados:
        resultados.sort()  
        for registro in resultados:
            print(registro)
    else:
        print("No hay planes en ese rango de precios.")


def actualizar_precio(codigo, nuevo_precio, dicc_inscripciones):
    
    if buscar_codigo(codigo, dicc_inscripciones):
        for clave in dicc_inscripciones:
            if clave.upper() == codigo.upper():
                dicc_inscripciones[clave][0] = nuevo_precio
                return True
    return False


def agregar_plan(codigo, nombre, tipo, duracion, piscina, clases, horario, precio, cupos, dicc_planes, dicc_inscripciones):
    
    if buscar_codigo(codigo, dicc_planes):
        return False
    
    clave_limpia = codigo.upper()
    dicc_planes[clave_limpia] = [nombre, tipo, duracion, piscina, clases, horario]
    dicc_inscripciones[clave_limpia] = [precio, cupos]
    return True


def eliminar_plan(codigo, dicc_planes, dicc_inscripciones):
   
    if buscar_codigo(codigo, dicc_planes):
        clave_real = None
        for clave in dicc_planes:
            if clave.upper() == codigo.upper():
                clave_real = clave
                break
        
        if clave_real:
            del dicc_planes[clave_real]
            if clave_real in dicc_inscripciones:
                del dicc_inscripciones[clave_real]
            return True
    return False



while True:
    print("\n MENÚ PRINCIPAL ")
    print("1. Cupos por tipo de plan")
    print("2. Búsqueda de planes por rango de precio")
    print("3. Actualizar precio de plan")
    print("4. Agregar plan")
    print("5. Eliminar plan")
    print("6. Salir")
    print("-------------------------------")
    
    opcion = input("Ingrese opción: ").strip()
    
    if opcion == '1':
        tipo = input("Ingrese tipo de plan a consultar: ").strip()
        cupos_tipo(tipo, planes, inscripciones)
        
    elif opcion == '2':
        while True:
            try:
                p_min = int(input("Ingrese precio mínimo: "))
                p_max = int(input("Ingrese precio máximo: "))
                
                if p_min < 0 or p_max < 0 or p_min > p_max:
                    print("Valores lógicos incorrectos (no pueden ser negativos ni el mínimo mayor al máximo).")
                    continue
                break
            except ValueError:
                print("Debe ingresar valores enteros")
                
        busqueda_precio(p_min, p_max, planes, inscripciones)
        
    elif opcion == '3':
        while True:
            codigo_act = input("Ingrese el código del plan: ").strip()
            
            while True:
                try:
                    nuevo_p = int(input("Ingrese el nuevo precio: "))
                    if nuevo_p < 0:
                        print("El precio no puede ser negativo.")
                        continue
                    break
                except ValueError:
                    print("Debe ingresar un valor entero para el precio.")
            
            if actualizar_precio(codigo_act, nuevo_p, inscripciones):
                print("Precio actualizado con éxito.")
            else:
                print("El código no existe.")
                
            resp = input("¿Desea actualizar otro precio (s/n)?: ").strip().lower()
            if resp != 's':
                break
                
    elif opcion == '4':
        print("\n--- Formulario de Registro de Plan ---")
        cod = input("Código de plan: ").strip()
        
        nombre = input("Nombre del plan: ").strip()
        while not nombre:
            print("Error: El nombre del plan no debe estar vacío.")
            nombre = input("Nombre del plan: ").strip()
            
        while True:
            tipo = input("Tipo de plan ('mensual', 'trimestral', 'anual'): ").strip().lower()
            if tipo in ['mensual', 'trimestral', 'anual']:
                break
            print("Error: Debe ser exactamente 'mensual', 'trimestral' o 'anual'.")
            
        while True:
            try:
                duracion = int(input("Duración del plan en meses: "))
                if duracion > 0:
                    break
                print("Error: Debe ser un número entero mayor que cero.")
            except ValueError:
                print("Debe ingresar un número entero válido.")
                
        def leer_booleano(mensaje):
            while True:
                r = input(mensaje).strip().lower()
                if r == 's': return True
                if r == 'n': return False
                print("Entrada inválida. Ingrese 's' (Sí) o 'n' (No).")

        piscina = leer_booleano("¿Incluye acceso a piscina? (s/n): ")
        clases = leer_booleano("¿Incluye clases grupales? (s/n): ")
        
        horario = input("Franja horaria disponible: ").strip()
        while not horario:
            print("Error: La franja horaria no debe estar vacía.")
            horario = input("Franja horaria disponible: ").strip()
            
        while True:
            try:
                precio = int(input("Precio del plan: "))
                cupos = int(input("Cupos disponibles iniciales: "))
                if precio >= 0 and cupos >= 0:
                    break
                print("El precio y los cupos no pueden ser negativos.")
            except ValueError:
                print("Debe ingresar valores numéricos enteros.")
                
        if agregar_plan(cod, nombre, tipo, duracion, piscina, clases, horario, precio, cupos, planes, inscripciones):
            print("Plan agregado")
        else:
            print("El código ya existe")
            
    elif opcion == '5':
        cod_eliminar = input("Ingrese el código del plan que desea eliminar: ").strip()
        
        if eliminar_plan(cod_eliminar, planes, inscripciones):
            print("Plan eliminado")
        else:
            print("El código no existe")
            
    elif opcion == '6':
        print("Programa finalizado.")
        break
        
    else:
        print("Opción inválida. Intente nuevamente.")
